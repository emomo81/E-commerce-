# Copy to .env.local and fill in. .env.local is git-ignored.

# --- Azure recommender (Option B: Container Apps) ---
# Local container:   http://localhost:8000/recommend
# Azure Container App: https://<app>.azurecontainerapps.io/recommend
RECS_URL=
# Only needed for Azure ML Managed Online Endpoint (key auth). Leave blank for Container Apps.
RECS_KEY=
